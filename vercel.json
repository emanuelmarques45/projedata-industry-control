{
  "version": 2,
  "builds": [
    { "src": "backend/**/*.js", "use": "@vercel/node" },
    { "src": "frontend/package.json", "use": "@vercel/static-build" }
  ],
  "rewrites": [
    { "source": "/backend/(.*)", "destination": "/backend/$1.js" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
